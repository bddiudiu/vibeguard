{
  "name": "@bddiudiu/vibeguard",
  "version": "0.0.0",
  "description": "AI 代码生成的语义安检门，在 git commit 前自动拦截幻觉错误与安全隐患",
  "repository": {
    "type": "git",
    "url": "https://github.com/bddiudiu/vibeguard"
  },
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "vibeguard": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "vibeguard:scan": "node dist/cli.js scan",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "code-review",
    "git-hook",
    "hallucination",
    "security",
    "ollama",
    "openai",
    "lint",
    "pre-commit"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.52.0",
    "better-sqlite3": "^11.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "husky": "^9.1.1",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
